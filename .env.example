### Backend API
PORT=3000
DEFAULT_LOCALIDADE=WTorre
GRAPH_RETRIES=2

# Opcao 1: string unica de conexao
DATABASE_URL=postgres://postgres:postgres@localhost:5432/salas_reuniao

# Opcao 2: parametros separados (use se nao utilizar DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=salas_reuniao

### Seed inicial de tenants
WTORRE_TENANT_ID=replace-wtorre-tenant-id
WTORRE_CLIENT_ID=replace-wtorre-client-id
WTORRE_CLIENT_SECRET=replace-wtorre-client-secret
ALLIANZ_TENANT_ID=replace-allianz-tenant-id
ALLIANZ_CLIENT_ID=replace-allianz-client-id
ALLIANZ_CLIENT_SECRET=replace-allianz-client-secret

### Frontend
FRONTEND_PORT=4200
